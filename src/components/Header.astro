---
const { pathname } = Astro.url;
const isEnglish = pathname.startsWith('/en/') || pathname === '/en' || pathname === '/en/';

const catMapEsToEn: Record<string, string> = {
  noticias: 'news',
  guias: 'guides',
  estrategia: 'strategy',
  analisis: 'analysis'
};

const catMapEnToEs: Record<string, string> = {
  news: 'noticias',
  guides: 'guias',
  strategy: 'estrategia',
  analysis: 'analisis'
};

function toEnglishPath(path: string): string {
  const normalized = path.replace(/\/+$/, '');
  if (normalized === '' || normalized === '/') return '/en';
  if (normalized === '/mazo') return '/en/deck';
  if (normalized.startsWith('/en')) return normalized;
  return `/en${normalized}`;
}

function toSpanishPath(path: string): string {
  const normalized = path.replace(/\/+$/, '');
  if (normalized === '/en' || normalized === '') return '/';
  if (normalized === '/en/deck') return '/mazo';
  if (!normalized.startsWith('/en/')) return normalized;

  const rest = normalized.replace('/en/', '');
  const parts = rest.split('/').filter(Boolean);

  if (parts.length === 0) return '/';

  // parts[0] is type, page slug, or static page slug
  const types = ['pokemon', 'yugioh', 'magic', 'lorcana', 'onepiece'];
  if (types.includes(parts[0]) && parts.length >= 2) {
    parts[1] = catMapEnToEs[parts[1]] || parts[1];
  }

  return `/${parts.join('/')}`;
}

const englishPath = toEnglishPath(pathname);
const spanishPath = toSpanishPath(pathname);

const tiposTCG = [
  { id: 'pokemon', label: 'Pokémon TCG', color: 'bg-yellow-500' },
  { id: 'yugioh', label: 'Yu-Gi-Oh!', color: 'bg-purple-600' },
  { id: 'magic', label: 'Magic: The Gathering', color: 'bg-gray-700' },
  { id: 'lorcana', label: 'Disney Lorcana', color: 'bg-amber-400' },
  { id: 'onepiece', label: 'One Piece Card Game', color: 'bg-red-600' },
];

const t = isEnglish ? {
  myTcg: 'My TCG',
  menu: 'Menu',
} : {
  myTcg: 'Mi TCG',
  menu: 'Menú',
};
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={isEnglish ? '/en' : '/'} class="text-xl font-bold tracking-tight text-gray-900">
      tcglat<span class="text-brand-red">.com</span>
    </a>

    <nav class="hidden md:flex items-center gap-6">
      <!-- Dropdown TCG -->
      <div class="relative group">
        <button class="text-sm text-gray-600 hover:text-brand-red transition-colors flex items-center gap-1 py-2">
          {t.myTcg}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute left-0 top-full mt-1 w-56 bg-white border border-gray-200 rounded-xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
          <div class="py-2">
            {tiposTCG.map(tipo => (
              <a href={isEnglish ? `/en/${tipo.id}` : `/${tipo.id}`} class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand-red transition-colors">
                <span class={`w-3 h-3 rounded-full ${tipo.color}`}></span>
                {tipo.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Deck Builder Link -->
      <a href={isEnglish ? '/en/deck' : '/mazo'} class="text-sm text-gray-600 hover:text-brand-red transition-colors py-2">
        Deck Builder
      </a>

      <!-- Language Selector -->
      <div class="flex items-center gap-2 border-l border-gray-200 pl-6">
        <a
          href={spanishPath}
          class={`text-sm font-medium transition-colors ${isEnglish ? 'text-gray-400 hover:text-brand-red' : 'text-brand-red'}`}
          aria-label="Español"
        >
          ES
        </a>
        <span class="text-gray-300">|</span>
        <a
          href={englishPath}
          class={`text-sm font-medium transition-colors ${isEnglish ? 'text-brand-red' : 'text-gray-400 hover:text-brand-red'}`}
          aria-label="English"
        >
          EN
        </a>
      </div>
    </nav>

    <button id="menu-toggle" class="md:hidden text-gray-700 p-2" aria-label="Menú">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>

<div id="mobile-menu" class="hidden md:hidden bg-white border-b border-gray-200">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-1">
    <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide px-2 py-2">{t.myTcg}</div>
    {tiposTCG.map(tipo => (
      <a href={isEnglish ? `/en/${tipo.id}` : `/${tipo.id}`} class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-700 hover:bg-gray-50 rounded-lg">
        <span class={`w-3 h-3 rounded-full ${tipo.color}`}></span>
        {tipo.label}
      </a>
    ))}

    <!-- Deck Builder Link Mobile -->
    <a href={isEnglish ? '/en/deck' : '/mazo'} class="px-3 py-2.5 text-sm text-gray-700 hover:bg-gray-50 rounded-lg">
      Deck Builder
    </a>

    <!-- Language Selector Mobile -->
    <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-center gap-3">
      <a href={spanishPath} class={`text-sm font-medium ${isEnglish ? 'text-gray-400' : 'text-brand-red'}`}>ES</a>
      <span class="text-gray-300">|</span>
      <a href={englishPath} class={`text-sm font-medium ${isEnglish ? 'text-brand-red' : 'text-gray-400'}`}>EN</a>
    </div>
  </nav>
</div>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>