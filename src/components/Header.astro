---
const { pathname } = Astro.url;

const tiposTCG = [
  { href: '/pokemon', label: 'Pokémon TCG', color: 'bg-yellow-500' },
  { href: '/yugioh', label: 'Yu-Gi-Oh!', color: 'bg-purple-600' },
  { href: '/magic', label: 'Magic: The Gathering', color: 'bg-gray-700' },
  { href: '/lorcana', label: 'Disney Lorcana', color: 'bg-amber-400' },
  { href: '/onepiece', label: 'One Piece Card Game', color: 'bg-red-600' },
];

const categorias = [
  { href: '/blog/categoria/noticias', label: 'Noticias' },
  { href: '/blog/categoria/guias', label: 'Guías' },
  { href: '/blog/categoria/estrategia', label: 'Estrategia' },
  { href: '/blog/categoria/analisis', label: 'Análisis' },
];
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-bold tracking-tight text-gray-900">
      tcglat<span class="text-brand-red">.com</span>
    </a>

    <nav class="hidden md:flex items-center gap-6">
      <!-- Dropdown TCG -->
      <div class="relative group">
        <button class="text-sm text-gray-600 hover:text-brand-red transition-colors flex items-center gap-1 py-2">
          Mi TCG
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute left-0 top-full mt-1 w-56 bg-white border border-gray-200 rounded-xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
          <div class="py-2">
            {tiposTCG.map(tipo => (
              <a href={tipo.href} class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand-red transition-colors">
                <span class={`w-3 h-3 rounded-full ${tipo.color}`}></span>
                {tipo.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Categorías -->
      {categorias.map(cat => (
        <a 
          href={cat.href} 
          class={`text-sm transition-colors ${
            pathname === cat.href 
              ? 'text-brand-red font-semibold' 
              : 'text-gray-600 hover:text-brand-red'
          }`}
        >
          {cat.label}
        </a>
      ))}
    </nav>

    <button id="menu-toggle" class="md:hidden text-gray-700 p-2" aria-label="Menú">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>

<div id="mobile-menu" class="hidden md:hidden bg-white border-b border-gray-200">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-1">
    <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide px-2 py-2">Mi TCG</div>
    {tiposTCG.map(tipo => (
      <a href={tipo.href} class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-700 hover:bg-gray-50 rounded-lg">
        <span class={`w-3 h-3 rounded-full ${tipo.color}`}></span>
        {tipo.label}
      </a>
    ))}
    <div class="border-t border-gray-100 my-2"></div>
    <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide px-2 py-2">Categorías</div>
    {categorias.map(cat => (
      <a href={cat.href} class={`text-sm py-2 px-3 ${pathname === cat.href ? 'text-brand-red font-semibold' : 'text-gray-600'}`}>
        {cat.label}
      </a>
    ))}
  </nav>
</div>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>