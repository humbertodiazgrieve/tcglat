---
const { post, type } = Astro.props;
const date = new Date(post.data.date).toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' });

const postType = type || post.data.type || 'pokemon';

const link = postType
  ? `/en/${postType}/${post.data.category}/${post.slug}`
  : `/en/blog/${post.data.category}/${post.slug}`;
---

<article class="bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
  {post.data.image && (
    <a href={link}>
      <img
        src={post.data.image}
        alt={post.data.title}
        class="w-full h-52 object-cover"
      />
    </a>
  )}
  <div class="p-5">
    <div class="flex items-center gap-2 text-xs mb-3">
      <span class="px-2 py-1 bg-brand-blue text-white font-semibold uppercase rounded">{post.data.category}</span>
      <span class="text-gray-400">•</span>
      <time class="text-gray-500">{date}</time>
    </div>
    <h2 class="text-lg font-bold text-gray-900 mb-2 leading-snug">
      <a href={link} class="hover:text-brand-red transition-colors">
        {post.data.title}
      </a>
    </h2>
    <p class="text-sm text-gray-600 leading-relaxed line-clamp-2">
      {post.data.description}
    </p>
  </div>
</article>
