---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-200 mt-16">
  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Marca -->
      <div>
        <a href="/" class="text-xl font-bold text-gray-900">
          tcglat<span class="text-brand-red">.com</span>
        </a>
        <p class="text-sm text-gray-500 mt-3 leading-relaxed">
          Tu fuente en español sobre Trading Card Games. Estrategias, noticias y guías para todos los jugadores.
        </p>
      </div>

      <!-- Secciones -->
      <div>
        <h3 class="text-sm font-semibold text-gray-900 mb-4 uppercase tracking-wide">Secciones</h3>
        <ul class="space-y-2">
          <li><a href="/blog/categoria/noticias" class="text-sm text-gray-500 hover:text-brand-red transition-colors">Noticias</a></li>
          <li><a href="/blog/categoria/guias" class="text-sm text-gray-500 hover:text-brand-red transition-colors">Guías</a></li>
          <li><a href="/blog/categoria/estrategia" class="text-sm text-gray-500 hover:text-brand-red transition-colors">Estrategia</a></li>
          <li><a href="/blog/categoria/analisis" class="text-sm text-gray-500 hover:text-brand-red transition-colors">Análisis</a></li>
        </ul>
      </div>

      <!-- Compañía -->
      <div>
        <h3 class="text-sm font-semibold text-gray-900 mb-4 uppercase tracking-wide">Compañía</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-gray-500 hover:text-brand-red transition-colors">Acerca de</a></li>
          <li><a href="/contacto" class="text-sm text-gray-500 hover:text-brand-red transition-colors">Contacto</a></li>
          <li><a href="/privacidad" class="text-sm text-gray-500 hover:text-brand-red transition-colors">Privacidad</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-200 mt-8 pt-6">
      <p class="text-xs text-gray-400 text-center">
        © {currentYear} tcglat.com — Todos los derechos reservados
      </p>
    </div>
  </div>
</footer>