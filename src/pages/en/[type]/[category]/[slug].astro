---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('postsEn');
  return posts.map(post => ({
    params: {
      type: post.data.type || 'pokemon',
      category: post.data.category,
      slug: post.slug
    },
    props: { post }
  }));
}

const { post } = Astro.props;
const { headings, Content } = await post.render();

const type = post.data.type || 'pokemon';

const typesInfo = {
  pokemon: { name: 'Pokémon TCG', color: 'bg-yellow-500' },
  yugioh: { name: 'Yu-Gi-Oh!', color: 'bg-purple-600' },
  magic: { name: 'Magic: The Gathering', color: 'bg-gray-700' },
  lorcana: { name: 'Disney Lorcana', color: 'bg-amber-400' },
  onepiece: { name: 'One Piece Card Game', color: 'bg-red-600' },
};

const info = typesInfo[type] || typesInfo.pokemon;

const allPosts = await getCollection('postsEn');
const relatedPosts = allPosts
  .filter(p => p.data.type === type && p.data.category === post.data.category && p.slug !== post.slug)
  .slice(0, 3);

const date = new Date(post.data.date).toLocaleDateString('en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});

const categoryLabels: Record<string, string> = {
  news: 'News',
  guides: 'Guides',
  strategy: 'Strategy',
  analysis: 'Analysis'
};
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <Header />

  <main class="max-w-7xl mx-auto px-4 md:px-6 py-8 md:py-10">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/en" class="hover:text-brand-red">Home</a>
      <span>/</span>
      <a href={`/en/${type}`} class="hover:text-brand-red flex items-center gap-1">
        <span class={`w-2 h-2 rounded-full ${info.color}`}></span>
        {info.name}
      </a>
      <span>/</span>
      <a href={`/en/${type}/${post.data.category}`} class="hover:text-brand-red capitalize">
        {categoryLabels[post.data.category] || post.data.category}
      </a>
      <span>/</span>
      <span class="text-gray-900 font-medium truncate">{post.data.title}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10">
      <!-- Sidebar (first on mobile, second on desktop) -->
      <aside class="lg:col-span-4 lg:order-2">
        <div class="lg:sticky lg:top-20 space-y-6">
          <!-- Summary / Insights -->
          {post.data.insights && post.data.insights.length > 0 && (
            <div class="bg-white rounded-xl border border-gray-200 p-5">
              <h3 class="text-sm font-semibold text-gray-900 mb-3 uppercase tracking-wide">Summary</h3>
              <ul class="space-y-2.5">
                {post.data.insights.map(insight => (
                  <li class="flex items-start gap-2 text-sm text-gray-700">
                    <svg class="w-4 h-4 text-brand-blue mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    <span>{insight}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Table of contents (collapsible) -->
          {headings && headings.length > 0 && (
            <details class="bg-white rounded-xl border border-gray-200 p-5">
              <summary class="text-sm font-semibold text-gray-900 uppercase tracking-wide cursor-pointer flex items-center justify-between list-none">
                <span>Table of contents</span>
                <svg class="w-4 h-4 text-gray-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <ul class="space-y-2 mt-3">
                {headings.map((heading, i) => (
                  <li style={`padding-left: ${(heading.depth - 1) * 1}rem`}>
                    <a href={`#${heading.slug}`} class="text-sm text-gray-600 hover:text-brand-red transition-colors">
                      {i + 1}. {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          )}
        </div>
      </aside>

      <!-- Main article (second on mobile, first on desktop) -->
      <div class="lg:col-span-8 lg:order-1">
        <!-- Type and category tags -->
        <div class="flex flex-wrap gap-2 mb-4">
          <a href={`/en/${type}`} class="text-xs font-semibold text-white px-3 py-1.5 rounded uppercase tracking-wider hover:opacity-90 transition-opacity flex items-center gap-1.5" style={`background-color: ${type === 'pokemon' ? '#EAB308' : type === 'magic' ? '#374151' : type === 'yugioh' ? '#7C3AED' : type === 'lorcana' ? '#F59E0B' : '#DC2626'}`}>
            <span class={`w-2 h-2 rounded-full bg-white/80`}></span>
            {info.name}
          </a>
          <a href={`/en/${type}/${post.data.category}`} class="text-xs font-semibold text-white bg-brand-blue px-3 py-1.5 rounded uppercase tracking-wider hover:bg-brand-red transition-colors">
            {post.data.category}
          </a>
        </div>

        <!-- Title -->
        <h1 class="text-2xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">
          {post.data.title}
        </h1>

        <!-- Meta -->
        <div class="flex items-center gap-2 md:gap-3 text-sm text-gray-500 mb-6">
          <span>By: <strong class="text-gray-700">{post.data.author || 'tcglat'}</strong></span>
          <span>|</span>
          <time datetime={post.data.date}>{date}</time>
        </div>

        <!-- Featured image -->
        {post.data.image && (
          <img
            src={post.data.image}
            alt={post.data.title}
            class="w-full h-48 md:h-80 object-cover rounded-xl mb-8"
          />
        )}

        <!-- Content -->
        <div class="bg-white rounded-xl border border-gray-200 p-4 md:p-8">
          <article class="prose prose-lg max-w-none prose-headings:font-bold prose-headings:text-gray-900 prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-xl prose-h3:mt-8 prose-p:text-gray-700 prose-p:leading-relaxed prose-a:text-brand-blue prose-strong:text-gray-900 prose-li:text-gray-700 prose-img:rounded-lg prose-table:w-full prose-th:bg-gray-100 prose-th:p-3 prose-td:p-3 prose-td:border prose-td:border-gray-200">
            <Content />
          </article>
        </div>

        <!-- Categories and Tags at the end -->
        <div class="bg-white rounded-xl border border-gray-200 p-4 md:p-6 mt-6">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
            <!-- Categories -->
            <div>
              <h3 class="text-sm font-semibold text-gray-900 mb-3 uppercase tracking-wide">Categories</h3>
              <div class="flex flex-wrap gap-2">
                <a href={`/en/${type}/news`} class="px-4 py-2 text-xs font-medium bg-gray-50 border border-gray-200 rounded-lg text-gray-700 hover:bg-brand-blue hover:text-white hover:border-brand-blue transition-colors">News</a>
                <a href={`/en/${type}/guides`} class="px-4 py-2 text-xs font-medium bg-gray-50 border border-gray-200 rounded-lg text-gray-700 hover:bg-brand-blue hover:text-white hover:border-brand-blue transition-colors">Guides</a>
                <a href={`/en/${type}/strategy`} class="px-4 py-2 text-xs font-medium bg-gray-50 border border-gray-200 rounded-lg text-gray-700 hover:bg-brand-blue hover:text-white hover:border-brand-blue transition-colors">Strategy</a>
                <a href={`/en/${type}/analysis`} class="px-4 py-2 text-xs font-medium bg-gray-50 border border-gray-200 rounded-lg text-gray-700 hover:bg-brand-blue hover:text-white hover:border-brand-blue transition-colors">Analysis</a>
              </div>
            </div>
            <!-- Tags -->
            {post.data.tags && post.data.tags.length > 0 && (
              <div>
                <h3 class="text-sm font-semibold text-gray-900 mb-3 uppercase tracking-wide">Tags</h3>
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map(tag => (
                    <span class="text-xs px-3 py-1.5 bg-gray-50 border border-gray-200 text-gray-600 rounded-full">#{tag}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>

        <!-- Related articles -->
        {relatedPosts.length > 0 && (
          <div class="mt-10 pt-8 border-t border-gray-200">
            <h2 class="text-xl font-bold text-gray-900 mb-6">Related articles</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
              {relatedPosts.map(related => (
                <a href={`/en/${type}/${related.data.category}/${related.slug}`} class="bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow group">
                  {related.data.image && (
                    <img
                      src={related.data.image}
                      alt={related.data.title}
                      class="w-full h-32 sm:h-36 object-cover"
                    />
                  )}
                  <div class="p-4">
                    <p class="text-xs text-brand-blue font-medium uppercase mb-1">{related.data.category}</p>
                    <h3 class="text-sm font-semibold text-gray-800 group-hover:text-brand-red transition-colors line-clamp-2 leading-snug">
                      {related.data.title}
                    </h3>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>
