---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');

const tiposTCG = [
  { 
    id: 'pokemon', 
    nombre: 'Pokémon TCG', 
    descripcion: 'El juego de cartas más icónico del mundo. Atrapa, entrena y lucha.',
    color: 'from-yellow-400 to-yellow-600',
    bgColor: 'bg-yellow-50',
    borderColor: 'border-yellow-200',
    textColor: 'text-yellow-700',
    icon: '⚡',
    postsCount: posts.filter(p => p.data.tipo === 'pokemon').length
  },
  { 
    id: 'yugioh', 
    nombre: 'Yu-Gi-Oh!', 
    descripcion: 'El juego de cartascoleccionables definitivo. Los juegos nunca terminan.',
    color: 'from-purple-600 to-purple-800',
    bgColor: 'bg-purple-50',
    borderColor: 'border-purple-200',
    textColor: 'text-purple-700',
    icon: '👑',
    postsCount: posts.filter(p => p.data.tipo === 'yugioh').length
  },
  { 
    id: 'magic', 
    nombre: 'Magic: The Gathering', 
    descripcion: 'El precursor de los TCG. Magia, estrategia y un multiverso infinito.',
    color: 'from-gray-600 to-gray-800',
    bgColor: 'bg-gray-50',
    borderColor: 'border-gray-200',
    textColor: 'text-gray-700',
    icon: '🪄',
    postsCount: posts.filter(p => p.data.tipo === 'magic').length
  },
  { 
    id: 'lorcana', 
    nombre: 'Disney Lorcana', 
    descripcion: 'Donde la magia de Disney se encuentra con la estrategia TCG.',
    color: 'from-amber-300 to-amber-500',
    bgColor: 'bg-amber-50',
    borderColor: 'border-amber-200',
    textColor: 'text-amber-700',
    icon: '✨',
    postsCount: posts.filter(p => p.data.tipo === 'lorcana').length
  },
  { 
    id: 'onepiece', 
    nombre: 'One Piece Card Game', 
    descripcion: 'Embárcate en una aventura piratesca. ¡Serás el Rey de los Piratas!',
    color: 'from-red-500 to-red-700',
    bgColor: 'bg-red-50',
    borderColor: 'border-red-200',
    textColor: 'text-red-700',
    icon: '🏴‍☠️',
    postsCount: posts.filter(p => p.data.tipo === 'onepiece').length
  },
];

const recentPosts = posts
  .sort((a, b) => new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime())
  .slice(0, 6);

---

<BaseLayout title=" tcglat - Tu portal de TCG en Español" description=" tcglat.com - El mejor contenido sobre Trading Card Games: Pokémon, Yu-Gi-Oh!, Magic, Lorcana y One Piece.">
  <Header />
  
  <main class="max-w-7xl mx-auto px-4 md:px-6 py-8 md:py-10">
    <!-- Hero Section -->
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Bienvenido a <span class="text-brand-red">tcglat</span>
      </h1>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Somos una página informativa sobre trading card games.
      </p>
    </div>

    <!-- TCG Selector -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6 mb-12">
      {tiposTCG.map(tipo => (
        <a 
          href={`/${tipo.id}`}
          class={`group relative overflow-hidden ${tipo.bgColor} ${tipo.borderColor} border-2 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 hover:-translate-y-1`}
        >
          <div class={`absolute inset-0 bg-gradient-to-br ${tipo.color} opacity-0 group-hover:opacity-10 transition-opacity`}></div>
          
          <div class="relative">
            <span class="text-4xl mb-4 block">{tipo.icon}</span>
            <h2 class={`text-xl font-bold ${tipo.textColor} mb-2`}>
              {tipo.nombre}
            </h2>
            <p class="text-sm text-gray-600 mb-4">
              {tipo.descripcion}
            </p>
            <div class="flex items-center justify-between">
              <span class={`text-xs font-medium ${tipo.textColor} bg-white/60 px-3 py-1 rounded-full`}>
                {tipo.postsCount} artículo{tipo.postsCount !== 1 ? 's' : ''}
              </span>
              <span class="text-sm font-medium text-gray-500 group-hover:text-brand-red transition-colors flex items-center gap-1">
                Ver contenido
                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Artículos Recientes -->
    <div class="border-t border-gray-200 pt-10 mt-8">
      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-6 text-center">
        Artículos Recientes
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentPosts.map(post => (
          <a 
            href={`/${post.data.tipo}/${post.data.categoria}/${post.slug}`}
            class="group bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition-all"
          >
            {post.data.imagen && (
              <div class="aspect-video bg-gray-100 overflow-hidden">
                <img 
                  src={post.data.imagen} 
                  alt={post.data.titulo}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-medium px-2 py-1 bg-gray-100 text-gray-600 rounded">
                  {post.data.tipo.toUpperCase()}
                </span>
                <span class="text-xs text-gray-400">
                  {new Date(post.data.fecha).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
                </span>
              </div>
              <h3 class="font-semibold text-gray-800 group-hover:text-brand-red transition-colors line-clamp-2">
                {post.data.titulo}
              </h3>
              {post.data.descripcion && (
                <p class="text-sm text-gray-500 mt-2 line-clamp-2">
                  {post.data.descripcion}
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Preguntas Frecuentes sobre TCG -->
    <div class="border-t border-gray-200 pt-10 mt-8">
      <h2 class="text-xl md:text-2xl font-bold text-gray-900 mb-6 text-center">
        Preguntas Frecuentes sobre TCG
      </h2>
      
      <div class="max-w-3xl mx-auto space-y-4">
        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
            <span class="font-semibold text-gray-800">¿Qué es un TCG (Trading Card Game)?</span>
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-5 pb-5 text-gray-600">
            Un TCG o juego de cartas colecionables es un juego de estrategia donde los jugadores construyen mazos con cartas que compran o intercambian. Cada carta representa criaturas, magia u otros elementos, y el objetivo es vencer al oponente reduciéndole puntos de vida o cumpliendo otras condiciones de victoria.
          </div>
        </details>

        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
            <span class="font-semibold text-gray-800">¿Cuáles son los juegos de TCG más populares?</span>
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-5 pb-5 text-gray-600">
            Los TCG más importantes del mundo son: <strong>Pokémon TCG</strong> (el más vendido históricamente), <strong>Magic: The Gathering</strong> (creado en 1993 y considerado el precursor de todos los TCG), <strong>Yu-Gi-Oh!</strong> (fenómeno mundial especialmente en Asia y América), <strong>Disney Lorcana</strong> (el TCG más nuevo con mayor crecimiento) y <strong>One Piece Card Game</strong> (basado en el anime más popular de Japón).
          </div>
        </details>

        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
            <span class="font-semibold text-gray-800">¿Invertir en cartas de TCG es seguro?</span>
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-5 pb-5 text-gray-600">
            Invertir en TCG puede ser rentable, pero conlleva riesgos. Algunas cartas raras han appreciated significativamente (como cartas de Pokémon de primera edición o Black Lotus de Magic), pero el mercado es volátil y muchas cartas pierden valor con el tiempo. Es importante investigar, conocer las tendencias del metajuego y tratar la inversión como un complemento, no como una fuente principal de ingresos.
          </div>
        </details>

        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
            <span class="font-semibold text-gray-800">¿Cuál es la mejor forma de empezar en los TCG?</span>
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-5 pb-5 text-gray-600">
            Lo mejor es elegir un juego que te apasione y empezar con un mazo de inicio (Theme Deck). Dedica tiempo a aprender las reglas básicas, juega con amigos o en tournaments locales, y gradually ve expandiendo tu colección. No es necesario gastar mucho al principio; la práctica y la estrategia son más importantes que las cartas más caras.
          </div>
        </details>

        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
            <span class="font-semibold text-gray-800">¿Las cartas de TCG funcionan en tournaments oficiales?</span>
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-5 pb-5 text-gray-600">
            Sí, pero cada TCG tiene sus propios formatos y restricciones. Los formats más comunes son <strong>Standard</strong> (solo expansiones recientes) y <strong>Expanded</strong> (más histórico). Cada juego tiene organizaciones oficiales: Play! Pokémon para Pokémon, competitive REL para Magic, y sistemas similares para Yu-Gi-Oh! y Lorcana. Para jogar en tournaments, las cartas deben estar en condiciones aptas para juego (sin daño que afecte el mazo del oponente).
          </div>
        </details>

        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
            <span class="font-semibold text-gray-800">¿Cuál TCG debería elegir: Pokémon, Magic, Yu-Gi-Oh!, Lorcana u One Piece?</span>
            <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="px-5 pb-5 text-gray-600">
            Depende de tus preferencias: <strong>Pokémon</strong> es ideal para principiantes y coleccionistas casuales. <strong>Magic</strong> ofrece la mayor profundidad estratégica y variedad de formatos. <strong>Yu-Gi-Oh!</strong> es perfecto para quienes buscan acción rápida y combos espectaculares. <strong>Lorcana</strong> combina la magia de Disney con mecánica moderna. <strong>One Piece</strong> es ideal para fans del anime. ¡Todos tienen comunidades activas en Latinoamérica!
          </div>
        </details>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
