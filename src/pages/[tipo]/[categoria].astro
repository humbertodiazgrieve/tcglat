---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const tipos = ['pokemon', 'yugioh', 'magic', 'lorcana', 'onepiece'];
  const categorias = ['noticias', 'guias', 'estrategia', 'analisis'];
  
  const paths = [];
  
  for (const tipo of tipos) {
    for (const cat of categorias) {
      const tipoPosts = posts.filter(p => p.data.tipo === tipo && p.data.categoria === cat);
      paths.push({
        params: { tipo, categoria: cat },
        props: { 
          tipo, 
          categoria: cat,
          posts: tipoPosts
        }
      });
    }
  }
  
  return paths;
}

const { tipo, categoria, posts } = Astro.props;

const tiposInfo = {
  pokemon: { nombre: 'Pokémon TCG', color: 'bg-yellow-500' },
  yugioh: { nombre: 'Yu-Gi-Oh!', color: 'bg-purple-600' },
  magic: { nombre: 'Magic: The Gathering', color: 'bg-gray-700' },
  lorcana: { nombre: 'Disney Lorcana', color: 'bg-amber-400' },
  onepiece: { nombre: 'One Piece Card Game', color: 'bg-red-600' },
};

const info = tiposInfo[tipo];
const titulo = categoria.charAt(0).toUpperCase() + categoria.slice(1);

const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime()
);

const otrasCategorias = ['noticias', 'guias', 'estrategia', 'analisis'].filter(c => c !== categoria);

const textosSEO: Record<string, Record<string, string>> = {
  pokemon: {
    noticias: `Mantente al día con las últimas noticias de Pokémon TCG en tcglat. El mundo de los juegos de cartas coleccionables evoluciona constantemente con nuevas expansiones, anuncios oficiales, torneos internacionales y cambios en el metajuego. En esta sección recopilamos la información más relevante para jugadores y coleccionistas de habla hispana, con análisis claros y actualizados sobre lo que está sucediendo en el universo Pokémon. Desde nuevos sets y cartas promocionales hasta eventos de prelanzamiento y resultados de competiciones, aquí encontrarás todo lo que necesitas saber para no perderte ningún detalle. Nuestro objetivo es que estés informado con contenido preciso, útil y pensado para la comunidad TCG de Latinoamérica y España.`,
    guias: `Descubre guías completas de Pokémon TCG para mejorar como jugador, coleccionista o inversor. En tcglat explicamos desde las reglas básicas para principiantes hasta estrategias avanzadas para competir en torneos locales e internacionales. Aprende cómo construir mazos sólidos, identificar cartas valiosas, organizar tu colección y comprar productos sellados de forma inteligente. También cubrimos temas como rarezas, tipos de cartas, formatos legales y consejos para proteger tus piezas. Cada guía está escrita en español y pensada para aportar valor real, ya sea que juegues ocasionalmente o busques destacar en el competitivo.`,
    estrategia: `Domina el metajuego de Pokémon TCG con análisis estratégicos profundos y actualizados. En esta sección de tcglat encontrarás artículos dedicados a los mejores mazos del momento, sinergias entre cartas, contramatchups y decisiones clave para ganar más partidas. Analizamos arquetipos populares, cartas clave de cada formato y cómo aprovechar las mecánicas más recientes de la serie Escarlata y Violeta. Ya sea que compitas en Play! Pokémon, torneos locales o simplemente quieras mejorar tus partidas contra amigos, aquí tienes contenido práctico para subir de nivel.`,
    analisis: `Explora análisis detallados del universo Pokémon en tcglat. Desde la historia de los videojuegos y las generaciones de criaturas hasta el valor de cartas específicas y tendencias del mercado coleccionable, esta sección profundiza en los temas que más interesan a los fans. Examinamos personajes icónicos, regiones, mecánicas competitivas y el impacto cultural de la franquicia. Cada artículo está pensado para ofrecer perspectiva, datos útiles y curiosidades que enriquecen tu experiencia como jugador, coleccionista o seguidor de Pokémon.`
  },
  yugioh: {
    noticias: `Entérate de las últimas noticias de Yu-Gi-Oh! en español con tcglat. Cubrimos lanzamientos de nuevas expansiones, cambios en la banlist, anuncios de productos coleccionables y eventos relevantes del juego de cartas más popular de Konami. Nuestro equipo selecciona la información más importante para jugadores y coleccionistas de Latinoamérica y España, presentándola de forma clara y accesible. Si quieres estar al día sobre el metajuego, torneos y novedades del universo Yu-Gi-Oh!, esta sección es tu punto de referencia constante.`,
    guias: `Aprende a jugar Yu-Gi-Oh! y domina sus reglas con las guías de tcglat. Desde conceptos básicos como invocaciones, tipos de cartas y fases del turno, hasta estrategias más avanzadas para construir mazos competitivos. Te explicamos cómo funciona el Extra Deck, las mecánicas de enlace, sincros y xyz, y qué debes considerar al comprar sobres o singles. Nuestras guías están dirigidas tanto a jugadores nuevos que necesitan una base sólida como a duelistas experimentados que buscan perfeccionar su conocimiento del juego.`,
    estrategia: `Mejora tu nivel en Yu-Gi-Oh! con análisis estratégicos de tcglat. Estudiamos los mazos más competitivos del formato, combos populares, tech choices y cómo enfrentar los arquetipos dominantes. Comprender el metajuego, anticipar las jugadas del rival y optimizar cada recurso son habilidades fundamentales en un juego tan rápido como Yu-Gi-Oh!. Aquí encontrarás artículos prácticos que te ayudarán a tomar mejores decisiones durante tus duelos y a prepararte para competir en torneos locales y regionales.`,
    analisis: `Sumérgete en el análisis del universo Yu-Gi-Oh! en tcglat. Revisamos la historia del juego, arquetipos icónicos, cartas míticas y el impacto del anime y el manga en el TCG. También analizamos el valor de cartas especiales, productos de colección y el estado del mercado secundario. Si eres fan de la franquicia, esta sección te ofrece contenido profundo, curiosidades y reflexiones sobre uno de los juegos de cartas más influyentes de la historia.`
  },
  magic: {
    noticias: `Las últimas noticias de Magic: The Gathering llegan a tcglat en español. Desde anuncios de nuevos sets y expansiones colaborativas hasta cambios de formato, eventos de prerelease y resultados de torneos competitivos. Magic sigue siendo el TCG más profundo y consolidado del mercado, con un ecosistema que no deja de crecer. En esta sección te mantenemos informado sobre todo lo que necesitas saber para jugar, coleccionar o invertir en cartas de Magic, con análisis pensados para hispanohablantes de Latinoamérica y España.`,
    guias: `Aprende a jugar Magic: The Gathering con guías completas en español. Te explicamos los conceptos esenciales: tipos de cartas, fases del turno, maná, colores de magia, formatos de juego y cómo construir tu primer mazo. También cubrimos temas como Commander, Standard, Draft y Sealed, además de consejos para comprar productos, organizar tu colección y proteger tus cartas. Si estás empezando o quieres profundizar en el juego más influyente de la historia, aquí encontrarás contenido útil y bien estructurado.`,
    estrategia: `Desarrolla tu habilidad competitiva en Magic: The Gathering con análisis estratégicos de tcglat. Estudiamos arquetipos del metajuego, construcción de mazos, sideboarding y decisiones clave en cada fase de la partida. Magic exige planificación, conocimiento de interacciones y capacidad de adaptación, cualidades que puedes mejorar con práctica y buena información. Nuestros artículos te ayudan a entender qué cartas y estrategias funcionan en cada formato, para que afrontes tus torneos con mayor confianza.`,
    analisis: `Analizamos en profundidad el universo de Magic: The Gathering en tcglat. Desde la historia del juego y sus planos más icónicos hasta el valor de cartas reservadas, ediciones especiales y tendencias del mercado. Magic no es solo un juego: es un fenómeno cultural que ha definido el género de los TCG durante décadas. En esta sección exploramos lore, mecánicas, productos de colección y todo aquello que hace de Magic una experiencia única para jugadores e inversores.`
  },
  lorcana: {
    noticias: `Descubre las últimas noticias de Disney Lorcana en tcglat. El TCG más exitoso de los últimos años continúa creciendo con nuevos sets, cartas promocionales, eventos organizados y colaboraciones. Mantente informado sobre lanzamientos, cambios de metajuego y novedades del juego que combina la magia de Disney con la estrategia de los juegos de cartas. Nuestra cobertura en español te acerca la información esencial para jugar y coleccionar Lorcana de forma inteligente.`,
    guias: `Aprende a jugar Disney Lorcana con nuestras guías en español. Te explicamos las reglas básicas, tipos de cartas, mecánica de tinta, desafíos de personajes y cómo construir un mazo equilibrado. Lorcana es un juego accesible para principiantes pero con profundidad suficiente para jugadores competitivos. Aquí encontrarás consejos para empezar, estrategias de draft y recomendaciones para comprar sobres y productos de colección en tu región.`,
    estrategia: `Mejora tu rendimiento en Disney Lorcana con análisis estratégicos de tcglat. Estudiamos los personajes y canciones más efectivos, sinergias de colores, control del board y timing de desafíos. Conocer el metajuego y aprovechar las habilidades de tus cartas es clave para ganar partidas. Nuestros artículos te ofrecen mazos, ideas y consejos prácticos para competir en locales y eventos de tu comunidad.`,
    analisis: `Explora el mundo de Disney Lorcana desde un enfoque analítico en tcglat. Revisamos la evolución del juego, ilustraciones de artistas, diseño de cartas, valor de productos y el impacto de Lorcana en el mercado de TCG. Si te interesa entender más allá de las reglas, esta sección ofrece artículos sobre lore, tendencias de coleccionismo y la posición de Lorcana frente a otros juegos de cartas.`
  },
  onepiece: {
    noticias: `Mantente informado sobre One Piece Card Game con las noticias de tcglat. El juego de cartas basado en el anime más popular de Japón no para de crecer, con nuevas expansiones, eventos oficiales y anuncios constantes. En esta sección encontrarás información actualizada sobre lanzamientos, metajuego y novedades del TCG, presentada en español para la comunidad de Latinoamérica y España.`,
    guias: `Aprende a jugar One Piece Card Game con nuestras guías en español. Te explicamos los conceptos básicos: tipos de cartas, líderes, dones, ataque, bloqueo y cómo construir tu primer mazo. One Piece TCG combina la pasión por el anime con una mecánica dinámica y emocionante. Aquí encontrarás consejos para empezar, recomendaciones de productos y estrategias para disfrutar del juego desde tus primeras partidas.`,
    estrategia: `Domina el metajuego de One Piece Card Game con análisis estratégicos de tcglat. Estudiamos líderes populares, combinaciones de colores, timings de ataque y defensa, y cómo construir mazos competitivos. Cada decisión cuenta en este juego rápido y agresivo, por eso te ofrecemos contenido práctico para mejorar tu win rate y prepararte para torneos locales y eventos de tu comunidad.`,
    analisis: `Analizamos el universo de One Piece Card Game en tcglat. Desde la conexión con el anime y el manga hasta el diseño de cartas, valor de colección y evolución del juego. One Piece TCG ha conquistado a fans de todo el mundo por su temática, arte y jugabilidad. En esta sección exploramos lo que hace especial a este juego y su lugar dentro del panorama actual de los juegos de cartas coleccionables.`
  }
};

const textoSEO = textosSEO[tipo]?.[categoria] || `Explora ${titulo} de ${info.nombre} en tcglat. Contenido en español sobre juegos de cartas coleccionables, pensado para jugadores y coleccionistas de Latinoamérica.`;
---

<BaseLayout title={`${titulo} de ${info.nombre} | tcglat.com`} description={`Artículos de ${titulo} sobre ${info.nombre}`}>
  <Header />
  
  <main class="max-w-7xl mx-auto px-4 md:px-6 py-8 md:py-10">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand-red">Inicio</a>
      <span>/</span>
      <a href={`/${tipo}`} class="hover:text-brand-red flex items-center gap-1">
        <span class={`w-2 h-2 rounded-full ${info.color}`}></span>
        {info.nombre}
      </a>
      <span>/</span>
      <span class="text-gray-900 font-medium">{titulo}</span>
    </nav>

    <header class="mb-8">
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">
        {titulo} <span class="text-brand-red">{info.nombre}</span>
      </h1>
      <p class="text-sm text-gray-500 mb-4">{posts.length} artículo{posts.length !== 1 ? 's' : ''}</p>
      <p class="text-gray-600 leading-relaxed max-w-4xl">
        {textoSEO}
      </p>
    </header>

    <!-- Quick Links otras categorías -->
    <div class="flex flex-wrap gap-2 mb-8">
      {otrasCategorias.map(cat => (
        <a 
          href={`/${tipo}/${cat}`}
          class="px-4 py-2 text-sm font-medium bg-white border border-gray-200 rounded-lg text-gray-700 hover:bg-brand-blue hover:text-white hover:border-brand-blue transition-colors"
        >
          {cat.charAt(0).toUpperCase() + cat.slice(1)}
        </a>
      ))}
      <a 
        href={`/${tipo}`}
        class="px-4 py-2 text-sm font-medium bg-white border border-gray-200 rounded-lg text-gray-700 hover:bg-brand-red hover:text-white hover:border-brand-red transition-colors"
      >
        Ver todos
      </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10">
      <!-- Contenido principal -->
      <div class="lg:col-span-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-6">
          {sortedPosts.length === 0 ? (
            <p class="text-center text-gray-500 py-12 col-span-2">No hay artículos en esta categoría.</p>
          ) : (
            sortedPosts.map(post => <PostCard post={post} tipo={tipo} />)
          )}
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-4">
        <div class="lg:sticky lg:top-20">
          <Sidebar tipo={tipo} />
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
