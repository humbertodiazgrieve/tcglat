---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contacto" description="Contacta con tcglat.com">
  <Header />
  
  <main class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Contacto</h1>
    <div class="bg-white rounded-xl border border-gray-200 p-8">
      <p class="text-gray-700 leading-relaxed mb-6">
        ¿Tienes preguntas, sugerencias o quieres colaborar con nosotros? Escríbenos.
      </p>
      <div class="space-y-4">
        <div>
          <h2 class="text-sm font-semibold text-gray-900 mb-1 uppercase tracking-wide">Email</h2>
          <p class="text-gray-600">contacto@tcglat.com</p>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>