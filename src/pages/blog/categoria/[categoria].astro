---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PostCard from '../../../components/PostCard.astro';
import Sidebar from '../../../components/Sidebar.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const categorias = [...new Set(posts.map(post => post.data.categoria))];
  
  return categorias.map(categoria => ({
    params: { categoria },
    props: { 
      categoria,
      posts: posts.filter(post => post.data.categoria === categoria)
    }
  }));
}

const { categoria, posts } = Astro.props;
const titulo = categoria.charAt(0).toUpperCase() + categoria.slice(1);
---

<BaseLayout title={`${titulo} | tcglat.com`} description={`Artículos de ${titulo} sobre Trading Card Games`}>
  <Header />
  
  <main class="max-w-7xl mx-auto px-4 md:px-6 py-8 md:py-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10">
      <!-- Contenido principal -->
      <div class="lg:col-span-8">
        <header class="mb-8">
          <h1 class="text-3xl font-bold text-gray-900 mb-2">{titulo}</h1>
          <p class="text-sm text-gray-500">{posts.length} artículo{posts.length !== 1 ? 's' : ''}</p>
        </header>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-6">
          {posts.length === 0 ? (
            <p class="text-center text-gray-500 py-12 col-span-2">No hay artículos en esta categoría.</p>
          ) : (
            posts.map(post => <PostCard post={post} />)
          )}
        </div>

        <div class="mt-8">
          <a href="/" class="text-sm text-brand-red hover:underline">← Volver a todos los artículos</a>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-4">
        <div class="lg:sticky lg:top-20">
          <Sidebar />
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>